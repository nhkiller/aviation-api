{
  "functions": {
    "api/*": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-API-Token" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, PUT, DELETE, POST, OPTIONS" }
      ]
    }
  ]
}